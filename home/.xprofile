#!/bin/sh

gentoo-pipewire-launcher &
light -I &
setxkbmap -layout us -variant altgr-intl &
set-background &
airpods daemon \
  --fallback-sink alsa_output.pci-0000_00_1f.3-platform-skl_hda_dsp_generic.HiFi__HDMI1__sink \
  --fallback-sink alsa_output.pci-0000_00_1f.3-platform-skl_hda_dsp_generic.HiFi__Speaker__sink \
  --noise-cycle transparency,anc &
dwmstatus --daemon &
sxhkd &
udiskie --no-tray &
# xcompmgr -c -l0 -t0 -r0 -o.00 &
