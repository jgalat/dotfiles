#!/bin/sh

usage() {
  echo "usage: ssh-unlock [personal|key-name|user@host]" >&2
  exit 2
}

[ "$#" -le 1 ] || usage

SSH_DIR="${HOME}/.ssh"
name="${1:-personal}"

case "$name" in
  *@*)
    GPG_TTY="$(tty)"
    export GPG_TTY

    ssh -T "$name"
    exit
    ;;
esac

case "$name" in
  personal)
    key="$SSH_DIR/id_ed25519.pub"
    ;;
  ""|*[!A-Za-z0-9._-]*)
    usage
    ;;
  *)
    key="$SSH_DIR/id_$name.pub"
    if [ ! -f "$key" ]; then
      key="$SSH_DIR/id_ed_$name.pub"
    fi
    ;;
esac

if [ ! -f "$key" ]; then
  echo "ssh-unlock: key not found for '$name'" >&2
  exit 1
fi

GPG_TTY="$(tty)"
export GPG_TTY

ssh-add -T "$key"
