#!/bin/sh

usage() {
  echo "usage: ssh-test [personal|key-name]" >&2
  exit 2
}

[ "$#" -le 1 ] || usage

SSH_DIR="${HOME}/.ssh"
name="${1:-personal}"

case "$name" in
  personal)
    key="$SSH_DIR/id_ed25519.pub"
    ;;
  ""|*[!A-Za-z0-9._-]*)
    usage
    ;;
  *)
    key="$SSH_DIR/id_$name.pub"
    if [ ! -f "$key" ]; then
      key="$SSH_DIR/id_ed_$name.pub"
    fi
    ;;
esac

if [ ! -f "$key" ]; then
  echo "ssh-test: key not found for '$name'" >&2
  exit 1
fi

fingerprint="$(ssh-keygen -E md5 -lf "$key" 2>/dev/null \
  | awk '{print $2}')"

if [ -z "$fingerprint" ]; then
  echo "ssh-test: could not read '$key'" >&2
  exit 1
fi

keyinfo="$(gpg-connect-agent "keyinfo --ssh-list --ssh-fpr=md5" /bye 2>/dev/null)" || {
  echo "ssh-test: could not query gpg-agent" >&2
  exit 1
}

cached="$(printf '%s\n' "$keyinfo" \
  | awk -v fingerprint="$fingerprint" \
    '$1 == "S" && $2 == "KEYINFO" && $9 == fingerprint {print $7}')"

if [ "$cached" = "1" ]; then
  echo "  $name unlocked" >&2
  exit 0
fi

echo "  $name locked" >&2
exit 1
