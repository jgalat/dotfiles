#!/bin/sh

dt() {
  date +"%d/%m/%Y %H:%M"
}

bat() {
  battery="$(acpi -b | head -n 1)"
  capacity="$(echo "$battery" | grep -o -P '\d+%')"
  remaining="$(echo "$battery" | grep -o -P '\d\d:\d\d')"

  ac="$(acpi -a | grep -o -P 'on|off')"
  status="-"
  if [ "$ac" = "on" ]; then
    status="+"
  fi

  ret="$status$capacity"
  if [ -n "$remaining" ]; then
    ret="${ret} (${remaining})"
  fi

  echo "$ret"
}

conn() {
  ifaces="$(find /sys/class/net -type l -not -lname '*virtual*' -printf '%f\n')"
  for iface in $ifaces; do
    status="$(cat /sys/class/net/"${iface}"/operstate)"
    if [ "$status" = "up" ]; then
      append=""
      if [ "$(echo "$iface" | cut -c1-1)" = "w" ]; then
        append="<$(wpa_cli status | grep '^ssid=' | sed 's/^ssid=//')>"
      else
        append="[--]"
      fi
      iface_status="$iface_status ${append}"
    fi
  done

  if [ -z "$iface_status" ]; then
    iface_status="--/--"
  fi

  vpn="$(sudo wg show interfaces)"
  if [ -n "$vpn"  ]; then
    iface_status="${iface_status} (${vpn})"
  fi

  iface_status="$(echo "$iface_status" | sed "s/^[[:space:]]//")"
  echo "$iface_status"
}

vol() {
  volume="$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '/MUTED/ {print 0; exit} {printf "%.0f\n", $2 * 100}')"

  pods="$(airpods info)"
  if [ "$pods" != 'off' ];then
    profile=" (bt $pods)"
  fi

  echo "$volume$profile"
}

bright() {
  light -G | sed 's/\.00$//'
}

cpu() {
  read -r _ a b c d rest < /proc/stat
  total=$((a + b + c + d))
  idle=$d
  sleep 0.2
  read -r _ a b c d rest < /proc/stat
  total2=$((a + b + c + d))
  idle2=$d
  echo "$((100 * ((total2 - total) - (idle2 - idle)) / (total2 - total)))"
}

temp() {
  sensors -u thinkpad-isa-0000 2>/dev/null | awk '/temp1_input/ {printf "%.0f", $2}'
}

recording() {
  rec status --dwm 2>/dev/null
}

dwmstatus() {
  rec_status="$(recording)"
  if [ -n "$rec_status" ]; then
    rec_status="$rec_status | "
  fi

  xsetroot -name "${rec_status}$(bright) | $(vol) | $(conn) | $(cpu) $(temp) | $(bat) | $(dt)" > /dev/null 2>&1
}

case "$1" in
  --daemon)
    while true; do
      dwmstatus
      sleep 10
    done
    ;;
  restart)
    pkill -f "dwmstatus --daemon"
    "$0" --daemon &
    ;;
  *)
    dwmstatus
    ;;
esac
